{
  "entities": {
    "SwiftCode": {
      "title": "SwiftCode",
      "description": "Represents a bank branch's SWIFT/BIC code details.",
      "type": "object",
      "properties": {
        "bic": { "type": "string" },
        "bank": { "type": "string" },
        "branch": { "type": "string" },
        "city": { "type": "string" },
        "country": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["bic", "bank", "country"]
    }
  },
  "firestore": {
    "/swiftCodes/{swiftCodeId}": {
      "schema": { "$ref": "#/entities/SwiftCode" },
      "description": "A global collection of SWIFT codes."
    }
  }
}
